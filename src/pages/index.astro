---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Ridhwan Zaman"
  description="Personal site of Ridhwan Zaman — work in progress."
>
  <main class="wip">
    <p class="wip-text">Work in progress ...</p>
    <img
      id="bubble"
      class="wip-bubble"
      src="/bubbles.png"
      alt=""
      aria-hidden="true"
      width="120"
      height="120"
    />
  </main>

  <script is:inline>
    const bubble = document.getElementById("bubble");
    const reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const SPEED = 0.12;
    let x = 0;
    let y = 0;
    let vx = SPEED;
    let vy = SPEED;
    let w = 0;
    let h = 0;
    let last = 0;

    function bounds() {
      w = bubble.offsetWidth;
      h = bubble.offsetHeight;
      x = Math.min(x, window.innerWidth - w);
      y = Math.min(y, window.innerHeight - h);
    }

    function frame(now) {
      const dt = last ? now - last : 16;
      last = now;

      const maxX = window.innerWidth - w;
      const maxY = window.innerHeight - h;

      x += vx * dt;
      y += vy * dt;

      if (x <= 0) {
        x = 0;
        vx = Math.abs(vx);
      } else if (x >= maxX) {
        x = maxX;
        vx = -Math.abs(vx);
      }

      if (y <= 0) {
        y = 0;
        vy = Math.abs(vy);
      } else if (y >= maxY) {
        y = maxY;
        vy = -Math.abs(vy);
      }

      bubble.style.transform = `translate(${x}px, ${y}px)`;
      requestAnimationFrame(frame);
    }

    function start() {
      bounds();
      x = (window.innerWidth - w) * 0.5;
      y = (window.innerHeight - h) * 0.5;
      bubble.style.transform = `translate(${x}px, ${y}px)`;
      if (!reduce) requestAnimationFrame(frame);
    }

    addEventListener("resize", bounds);
    if (bubble.complete) start();
    else bubble.addEventListener("load", start);
  </script>
</Layout>
