---
import Layout from "../../layouts/Layout.astro";
import "../../styles/blog.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmtDate = (d) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<Layout title="Writing" description="Essays and notes by Ridhwan Zaman.">
  <div class="blog">
    <main class="blog-main">
      <h1 class="blog-title">Writing</h1>

      {
        posts.length === 0 ? (
          <p class="blog-empty">Nothing published yet.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-row">
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {fmtDate(post.data.pubDate)}
                </time>
                <a class="post-link" href={`/blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </main>

    <footer class="blog-footer">
      <a href="/">Home</a>
      <a href="mailto:contact@ridhwanzaman.me">Contact</a>
      <a
        href="https://github.com/longestneckedgiraffe"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
    </footer>
  </div>
</Layout>
